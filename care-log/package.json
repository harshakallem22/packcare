{
  "name": "@packcare/care-log",
  "version": "0.1.0",
  "private": true,
  "description": "Owns MongoDB collections + the safety-critical dedupe logic.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
