# ─── Shared ───────────────────────────────────────────────
NODE_ENV=development

# ─── Datastores ───────────────────────────────────────────
# Single-node replica set (rs0) is required for transactions + change streams.
MONGODB_URI=mongodb://mongo:27017/packcare?replicaSet=rs0
REDIS_URL=redis://redis:6379

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me
# Leave GOOGLE_* blank to enable the dev-login fallback (NODE_ENV=development only).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ─── Service-to-service wiring ────────────────────────────
# Gateway forwards safety-critical writes to Care-Log over REST.
CARE_LOG_URL=http://care-log:5000
# Care-Log / Scheduler push real-time events back to the Gateway's /internal/emit.
GATEWAY_INTERNAL_URL=http://gateway:4000
INTERNAL_EMIT_TOKEN=change-me

# ─── Ports ────────────────────────────────────────────────
GATEWAY_PORT=4000
CARE_LOG_PORT=5000
SCHEDULER_PORT=5100

# ─── CORS ─────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:5173

# ─── Web (Vite, build-time) ───────────────────────────────
VITE_GATEWAY_URL=http://localhost:4000
